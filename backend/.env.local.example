# Database local SQLite
# POSTGRES_* are kept only because the current backend settings require them.
POSTGRES_USER=local
POSTGRES_PASSWORD=local
POSTGRES_DB=monitor_editais_local
DATABASE_URL=sqlite:///./app.db

# Security
SECRET_KEY=dev-local-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# SMTP local/mock
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=no-reply@example.com

# Crawler scheduler
CRAWLER_SCHEDULER_ENABLED=false
CRAWLER_INTERVAL_MINUTES=360
