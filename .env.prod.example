# Database for Docker staging/production-like validation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=monitor_editais

# Backend security. Replace before running a shared environment.
SECRET_KEY=change-me-generate-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend CORS for local Docker validation. Restrict to real staging domains before exposing externally.
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:80"]

# SMTP
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=localhost
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=no-reply@example.com

# Crawler scheduler. Keep disabled until manual seed/crawler validation is complete.
CRAWLER_SCHEDULER_ENABLED=false
CRAWLER_INTERVAL_MINUTES=360

# Admin/bootstrap helpers. ADMIN_PASSWORD can also be typed interactively instead of stored here.
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Smoke test credentials. Do not commit real values.
SMOKE_BASE_URL=http://localhost/api
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=
SMOKE_TIMEOUT=10
