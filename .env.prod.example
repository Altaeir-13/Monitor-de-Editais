# Compose identity and public endpoint
COMPOSE_PROJECT_NAME=monitor-editais-staging
IMAGE_TAG=staging
STAGING_DOMAIN=editais-staging.example.com
HTTP_PORT=80
HTTPS_PORT=443
TLS_CERT_DIRECTORY=./deploy/certs

# PostgreSQL. Replace placeholders before starting any shared environment.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=monitor_editais

# Backend runtime. Placeholder values are rejected in staging/production.
ENVIRONMENT=staging
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
API_ROOT_PATH=/api
OPENAPI_ENABLED=false
LOG_LEVEL=info
UVICORN_WORKERS=1
FORWARDED_ALLOW_IPS=*
BACKEND_CORS_ORIGINS=["https://editais-staging.example.com"]

# Frontend build
VITE_API_URL=/api

# SMTP
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=localhost
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=no-reply@example.com

# Crawler scheduler. Keep disabled for the initial remote validation.
CRAWLER_SCHEDULER_ENABLED=false
CRAWLER_INTERVAL_MINUTES=360

# Admin bootstrap. Supply ADMIN_PASSWORD only through the process environment.
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Remote smoke test. The base URL is the public origin, without /api.
SMOKE_BASE_URL=https://editais-staging.example.com
SMOKE_API_PREFIX=/api
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=
SMOKE_EXPECT_OPENAPI=false
SMOKE_TLS_VERIFY=true
SMOKE_TIMEOUT=10
