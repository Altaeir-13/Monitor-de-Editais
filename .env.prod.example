# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=monitor_editais

# Backend security
SECRET_KEY=change-me-generate-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend CORS for local production compose
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:80"]

# SMTP
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=localhost
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=no-reply@example.com

# Crawler scheduler
CRAWLER_SCHEDULER_ENABLED=false
CRAWLER_INTERVAL_MINUTES=360